# ---------- /start ----------
@dp.message(Command("start"))
async def cmd_start(message: Message):
    user = message.from_user
    session = SessionLocal()
    try:
        db_user = session.query(User).filter_by(telegram_id=user.id).first()
        if not db_user:
            ref_code = generate_referral_code()
            referrer_id = None
            args = message.text.split()
            if len(args) > 1 and args[1].startswith("ref_"):
                ref_code_param = args[1][4:]
                referrer = session.query(User).filter_by(referral_code=ref_code_param).first()
                if referrer and referrer.telegram_id != user.id:
                    referrer_id = referrer.telegram_id
            db_user = User(
                telegram_id=user.id,
                username=user.username,
                referral_code=ref_code,
                referrer_id=referrer_id
            )
            session.add(db_user)
            session.commit()
    finally:
        session.close()

    text = (
        "Здравствуйте!\n\n"
        "Мы рады предложить вам выгодную подписку на длительный срок. "
        "Вы сможете подключить до трёх устройств, и стоимость подписки вас приятно удивит.\n\n"
        "Не упустите возможность стать нашим клиентом!"
    )
