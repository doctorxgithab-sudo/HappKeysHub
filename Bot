@dp.message(Command("broadcast"))
async def cmd_broadcast(message: Message):
    if message.from_user.id not in ADMIN_IDS:
        await message.answer("⛔ У вас нет доступа к этой команде.")
        return

    text = message.text.removeprefix("/broadcast").strip()
    if not text:
        await message.answer("❌ Укажите текст рассылки после команды.\nПример: /broadcast Всем привет!")
        return

    session = SessionLocal()
    try:
        users = session.query(User).all()
        if not users:
            await message.answer("⚠️ В базе нет пользователей.")
            return

        await message.answer(f"📣 Начинаю рассылку на {len(users)} пользователей...")

        success = 0
        failed = 0
        for user in users:
            try:
                await bot.send_message(user.telegram_id, text)
                success += 1
                await asyncio.sleep(0.05)
            except Exception as e:
                logging.warning(f"Не удалось отправить {user.telegram_id}: {e}")
                failed += 1

        await message.answer(
            f"✅ Рассылка завершена.\n"
            f"▪️ Успешно: {success}\n"
            f"▪️ Не удалось: {failed}"
        )
    except Exception as e:
        await message.answer(f"❌ Ошибка при рассылке: {e}")
    finally:
        session.close()

